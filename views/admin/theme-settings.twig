{% extends 'admin.layouts.master' %}

{% block content %}
<div class="theme-settings p-6">
    <h1 class="text-2xl mb-6">إعدادات الثيم</h1>

    <form id="theme-settings-form" class="space-y-6">
        {% for section in settings %}
        <div class="section bg-white rounded-lg p-4 shadow">
            <h2 class="text-xl mb-4 flex items-center">
                <i class="{{ section.icon }} ml-2"></i>
                {{ section.title }}
            </h2>

            <div class="fields space-y-4">
                {% for field in section.fields %}
                <div class="field">
                    <label class="block mb-2">{{ field.label }}</label>
                    
                    {% if field.type == 'boolean' %}
                        <label class="switch">
                            <input type="checkbox" 
                                   name="{{ field.id }}"
                                   {% if theme.settings.get(field.id) %}checked{% endif %}
                            >
                            <span class="slider"></span>
                        </label>
                    
                    {% elseif field.type == 'color' %}
                        <input type="color"
                               name="{{ field.id }}"
                               value="{{ theme.settings.get(field.id, field.default) }}"
                               class="w-full h-10">
                    
                    {% elseif field.type == 'select' %}
                        <select name="{{ field.id }}" class="w-full p-2 border rounded">
                            {% for option in field.options %}
                                <option value="{{ option.value }}"
                                        {% if theme.settings.get(field.id) == option.value %}selected{% endif %}
                                >
                                    {{ option.label }}
                                </option>
                            {% endfor %}
                        </select>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}

        <button type="submit" class="bg-primary text-white px-6 py-2 rounded">
            حفظ التغييرات
        </button>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
document.getElementById('theme-settings-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const settings = Object.fromEntries(formData);
    
    try {
        const response = await fetch('/admin/api/theme/settings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(settings)
        });
        
        if (response.ok) {
            salla.notify.success('تم حفظ الإعدادات بنجاح');
        } else {
            throw new Error('فشل حفظ الإعدادات');
        }
    } catch (error) {
        salla.notify.error(error.message);
    }
});
</script>
{% endblock %} 