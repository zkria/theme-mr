<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>إدارة مكونات الثيم</h2>
            <button class="btn btn-primary" @click="showAddModal">إضافة مكون جديد</button>
        </div>
        
        <div class="card-body">
            {% for folder, componentsList in components %}
                <div class="component-section">
                    <h3>{{ folder }}</h3>
                    <div class="components-grid">
                        {% for component in componentsList %}
                            <div class="component-card">
                                <h4>{{ component.name }}</h4>
                                <div class="actions">
                                    <button @click="editComponent(component)">تعديل</button>
                                    <button @click="toggleComponent(component)">
                                        {{ component.is_active ? 'تعطيل' : 'تفعيل' }}
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div> 